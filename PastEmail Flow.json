    {
      "parameters": {
        "jsCode": "const text = $input.first().json.text;\nconst regex = /time:\\s*([^,]+),\\s*date:\\s*([^,]+)/g;\n\nlet match;\nconst reservations = [];\n\nwhile ((match = regex.exec(text)) !== null) {\n  const timeISO = match[1];\n  const date = match[2];\n\n  const time = new Date(timeISO).toISOString().substring(11, 19); // HH:MM:SS\n\n  reservations.push({\n    date,\n    time\n  });\n}\n\nreturn reservations.map(r => ({\n  json: {\n    date: r.date,\n    time: r.time,\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        464,
        80
      ],
      "id": "8838ef70-ac30-42db-b45c-8d06d0d69a3d",
      "name": "ReformatGPToutput"
    },
    {
      "parameters": {
        "jsCode": "const currentDate = DateTime.now().setZone('UTC').toISO();\n\nconst dt = DateTime.fromISO(currentDate);\nconst yearType = dt.isInLeapYear;\n\n// Return as single item\nreturn [\n  {\n    json: {\n      date: currentDate,\n      leapyear: yearType\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -400,
        -16
      ],
      "id": "ba1c7ac4-97ec-4e6d-a956-8bd98fc0454d",

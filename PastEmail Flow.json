    {
      "parameters": {
        "jsCode": "const sqlTuples = $('Microsoft SQL9').all().map(item => item.json);\nlet message = \"Zde jsou Vaše rezervace:\\n\\n\";\n\nfor (const row of sqlTuples) {\n  const email = row.Email;\n  const date = row.Reservation_date;\n  const time = row.Start_time;\n  if(!time){\n    message += `• ${email} - ${date}, čas neuveden\\n`;\n  }\n  else if(!date){\n    message += `• ${email} - ${time}, datum neuvedeno \\n`;\n  }\n  else{\n    message += `• ${email} - ${date}, ${time}\\n`;\n  }\n}\n\nreturn [{ json: { textBody: message } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
